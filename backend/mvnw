#!/usr/bin/env sh
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EMBEDDED_MVN="$SCRIPT_DIR/.maven/bin/mvn"

if [ -x "$EMBEDDED_MVN" ]; then
  exec "$EMBEDDED_MVN" "$@"
fi

if command -v mvn >/dev/null 2>&1; then
  exec mvn "$@"
fi

echo "Maven is not available. Install Maven or restore backend/.maven." >&2
exit 127
